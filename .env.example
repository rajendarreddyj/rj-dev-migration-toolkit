# Migration Toolkit — Environment Example
# Copy to .env and fill in values before running local tooling.

# GitHub Token (for MCP GitHub tool calls)
GITHUB_TOKEN=

# Jira credentials (for Atlassian MCP)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=

# AI Model settings (override for local dev)
COPILOT_MODEL=claude-sonnet-4
