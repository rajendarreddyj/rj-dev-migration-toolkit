{
  "name": "rj-dev-migration-toolkit",
  "version": "1.0.3",
  "description": "AI-powered migration pipeline: Java Servlet/JSP/ExtJS → Spring Boot 4.x + React. Works with GitHub Copilot, Claude Code, Antigravity, Codex, and Cursor.",
  "author": "migration-toolkit",
  "license": "MIT",
  "keywords": [
    "ai",
    "skills",
    "migration",
    "spring-boot",
    "react",
    "servlet",
    "extjs",
    "copilot",
    "claude",
    "codex",
    "cursor",
    "antigravity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/org/rj-dev-migration-toolkit"
  },
  "scripts": {
    "build": "markdownlint --config .markdownlint.json \"**/*.md\" --ignore-path .gitignore",
    "test": "npm run lint",
    "lint": "markdownlint --config .markdownlint.json \"**/*.md\" --ignore-path .gitignore",
    "format": "prettier --write \"**/*.md\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.md\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20"
  },
  "plugin": {
    "skills": "skills/",
    "agents": "agents/",
    "prompts": "prompts/",
    "instructions": "instructions/"
  }
}
